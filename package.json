{
  "name": "roboto-assessment",
  "version": "1.0.0",
  "dependencies": {
    "@workspace/env": "workspace:*"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@workspace/typescript-config": "workspace:*",
    "turbo": "^2.8.17",
    "typescript": "catalog:",
    "ultracite": "5.6.2"
  },
  "engines": {
    "node": ">=22"
  },
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:studio": "turbo run build --filter=studio",
    "build:web": "turbo run build --filter=web",
    "dev": "turbo run dev",
    "dev:studio": "turbo run dev --filter=studio",
    "dev:web": "turbo run dev --filter=web",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "check-types": "turbo run check-types",
    "test:e2e": "turbo run test:e2e"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "sanity-plugin-utils>sanity": ">=5",
        "sanity-plugin-lucide-icon-picker>sanity": ">=5",
        "sanity-plugin-lucide-icon-picker>@sanity/ui": ">=3",
        "@csstools/css-syntax-patches-for-csstree>css-tree": ">=3"
      }
    }
  },
  "packageManager": "pnpm@10.32.1"
}